    "astro-icon": "^1.1.5",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@types/node": "^22.0.0",
    "astro-pdf": "^1.8.0",
    "pagefind": "^1.4.0",
    "typescript": "^5.0.0"
  }
