---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import SiteHeader from '../components/shared/SiteHeader.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
import SearchModal from '../components/shared/SearchModal.astro';
import Hero from '../components/home/Hero.astro';
import ToolsStrip from '../components/home/ToolsStrip.astro';
import FeaturesGrid from '../components/home/FeaturesGrid.astro';
import AudienceGrid from '../components/home/AudienceGrid.astro';
import DownloadSection from '../components/home/DownloadSection.astro';
import ContributorsGrid from '../components/home/ContributorsGrid.astro';
import { getOrderedChapters, getChapterSlug } from '../lib/chapters';
import { getContributors } from '../lib/contributors';

const chapters = await getOrderedChapters();
const contributors = await getContributors();
---

<BaseLayout
  title="The Vibe Coder's Handbook — Free Guide to the Modern JavaScript Ecosystem"
  description="A free 48-page guide explaining React, Next.js, TypeScript, Tailwind, and 30+ tools in plain English. For vibe coders, returning devs, and curious minds."
>
  <SiteHeader variant="default" chapters={chapters} />
  <Hero />
  <div class="reveal"><ToolsStrip /></div>
  <div class="reveal"><FeaturesGrid /></div>
  <div class="reveal"><AudienceGrid /></div>

  <!-- Chapter List -->
  <section class="chapters-section" id="chapters">
    <div class="chapters-inner">
      <div class="section-header reveal">
        <span class="section-tag">Table of Contents</span>
        <h2 class="section-heading">Explore the curriculum</h2>
        <p class="section-desc">{chapters.length} chapters designed to be read in order or used as a reference map.</p>
      </div>

      <div class="chapters-grid">
        {chapters.map((ch, i) => {
          const slug = getChapterSlug(ch);
          const displayTools = ch.data.tools.slice(0, 3);
          const extraCount = ch.data.tools.length - 3;
          return (
            <a 
              href={`/chapters/${slug}`} 
              class="chapter-item reveal" 
              style={`transition-delay: ${(i % 2) * 100}ms`}
            >
              <div class="chapter-content">
                <span class="chapter-num">{ch.data.chapterLabel}</span>
                <h3 class="chapter-title">{ch.data.title}</h3>
                <p class="chapter-summary">{ch.data.description}</p>
                {displayTools.length > 0 && (
                  <div class="chapter-tags">
                    {displayTools.map((t: string) => <span class="tag-pill">{t}</span>)}
                    {extraCount > 0 && <span class="tag-more">+{extraCount}</span>}
                  </div>
                )}
              </div>
              <div class="chapter-arrow">
                <Icon name="lucide:arrow-right" class="chapter-arrow-icon" aria-hidden="true" />
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <div class="reveal"><ContributorsGrid contributors={contributors} limit={12} /></div>
  <div class="reveal"><DownloadSection /></div>
  <SiteFooter />
  <SearchModal />
</BaseLayout>

<style>
  .chapters-section {
    padding: 72px var(--space-md);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-raised) 58%, var(--surface-soft)), var(--surface-base));
  }

  .chapters-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 44px);
    border-radius: 32px;
    border: 1px solid var(--line-soft);
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--amber) 8%, transparent), transparent 34%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-raised) 95%, var(--surface-soft)), var(--surface-raised));
    box-shadow: 0 24px 72px rgba(15, 23, 42, 0.07);
  }

  .section-header {
    max-width: 500px;
    margin-bottom: 56px;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sky);
    padding: 8px 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--interactive-bg) 80%, var(--surface-raised));
    border: 1px solid var(--interactive-border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-strong);
    margin: 0 0 16px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 14ch;
    text-wrap: balance;
  }

  .section-desc {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .chapters-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .chapter-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--surface-raised);
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    padding: 32px;
    text-decoration: none;
    transition: border-color 0.25s var(--ease-out-quart), box-shadow 0.25s var(--ease-out-quart), transform 0.25s var(--ease-out-quart);
  }

  .chapter-item:hover,
  .chapter-item:focus-visible {
    border-color: var(--interactive-border-strong);
    background: var(--surface-soft);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .chapter-item:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 3px;
    border-radius: 12px;
  }

  .chapter-content {
    flex: 1;
    padding-right: 24px;
  }

  .chapter-arrow-icon {
    width: 20px;
    height: 20px;
  }

  .chapter-num {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--indigo);
    letter-spacing: 1px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  .chapter-title {
    font-family: 'DM Sans', sans-serif;
    font-size: var(--text-lg);
    font-weight: 650;
    color: var(--text-strong);
    margin: 0 0 10px;
    line-height: 1.3;
    text-wrap: balance;
  }

  .chapter-summary {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .chapter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag-pill {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    background: var(--surface-soft);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--line-soft);
  }

  .tag-more {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-subtle);
    padding: 2px 4px;
  }

  .chapter-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--surface-soft);
    border: 1px solid var(--line-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-subtle);
    transition: background-color 0.25s var(--ease-out-quart), border-color 0.25s var(--ease-out-quart), color 0.25s var(--ease-out-quart), transform 0.25s var(--ease-out-quart);
    flex-shrink: 0;
  }

  .chapter-item:hover .chapter-arrow,
  .chapter-item:focus-visible .chapter-arrow {
    background: linear-gradient(135deg, var(--blue), var(--indigo));
    border-color: transparent;
    color: var(--text-on-dark);
    transform: rotate(-45deg);
  }

  @media (max-width: 900px) {
    .chapters-section { padding: 56px 24px; }
    .chapters-inner { padding: 24px; border-radius: 24px; }
    .chapters-grid { grid-template-columns: 1fr; }
  }
</style>
