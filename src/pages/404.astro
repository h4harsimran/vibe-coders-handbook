---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/shared/SiteHeader.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
import { getOrderedChapters } from '../lib/chapters';

const chapters = await getOrderedChapters();
---

<BaseLayout
  title="Page Not Found — The Vibe Coder's Handbook"
  description="The page you're looking for doesn't exist."
>
  <SiteHeader variant="docs" chapters={chapters} />
  <main class="not-found">
    <h1 class="not-found-title">404</h1>
    <p class="not-found-subtitle">Page Not Found</p>
    <p class="not-found-desc">The page you're looking for doesn't exist. It might have been moved or removed.</p>
    <div class="not-found-links">
      <a href="/" class="btn-primary">← Back to Home</a>
      <a href="/chapters/introduction" class="not-found-secondary">Start Reading</a>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 200px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
  }

  .not-found-title {
    font-family: 'Space Mono', monospace;
    font-size: clamp(80px, 15vw, 160px);
    font-weight: 700;
    color: var(--text-subtle);
    line-height: 1;
    margin: 0;
  }

  .not-found-subtitle {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(28px, 4vw, 44px);
    color: var(--text-strong);
    margin: 0 0 16px;
  }

  .not-found-desc {
    color: var(--text-muted);
    font-size: 17px;
    max-width: 400px;
    margin: 0 0 32px;
    line-height: 1.6;
  }

  .not-found-links {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .not-found-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 10px;
    border: 1px solid var(--line-soft);
    background: var(--surface-raised);
    color: var(--text-strong);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s var(--ease-out-expo), border-color 0.2s var(--ease-out-expo), transform 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo);
  }

  .not-found-secondary:hover {
    background: var(--surface-soft);
    border-color: var(--interactive-border-strong);
    color: var(--sky);
    transform: translateY(-1px);
  }
</style>
