---
import BaseLayout from './BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import SiteHeader from '../components/shared/SiteHeader.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
import Sidebar from '../components/docs/Sidebar.astro';
import TableOfContents from '../components/docs/TableOfContents.astro';
import SearchModal from '../components/shared/SearchModal.astro';
import type { Chapter } from '../lib/chapters';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  chapters: Chapter[];
  headings: { depth: number; slug: string; text: string }[];
  readingTime: number;
}

const { title, description, currentSlug, chapters, headings, readingTime } = Astro.props;
---

<BaseLayout title={`${title} — The Vibe Coder's Handbook`} description={description}>
  <SiteHeader variant="docs" chapters={chapters} />
  <div class="docs-progress" aria-hidden="true">
    <div class="docs-progress-bar" data-reading-progress-bar></div>
  </div>

  <div class="docs-layout">
    <aside class="docs-sidebar" data-pagefind-ignore>
      <Sidebar chapters={chapters} currentSlug={currentSlug} />
    </aside>

    <main class="docs-content">
      <slot />
    </main>

    <aside class="docs-toc" data-pagefind-ignore>
      <TableOfContents headings={headings} readingTime={readingTime} />
    </aside>
  </div>

  <SiteFooter />

  <SearchModal />

  <script>
    const progressBar = document.querySelector<HTMLElement>('[data-reading-progress-bar]');
    const article = document.querySelector<HTMLElement>('.chapter-article');

    const updateReadingProgress = () => {
      if (!progressBar || !article) return;

      // Track progress against the article itself so the footer and sidebars do not skew the bar.
      const rect = article.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      const total = Math.max(article.scrollHeight - viewportHeight, 1);
      const traveled = Math.min(Math.max(-rect.top, 0), total);
      const progress = Math.max(0, Math.min(1, traveled / total));

      progressBar.style.transform = `scaleX(${progress})`;
    };

    updateReadingProgress();
    window.addEventListener('scroll', updateReadingProgress, { passive: true });
    window.addEventListener('resize', updateReadingProgress);
  </script>
</BaseLayout>

<style>
  .docs-progress {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    z-index: 45;
    height: 4px;
    background: color-mix(in srgb, var(--surface-overlay) 88%, transparent);
    border-bottom: 1px solid var(--line-soft);
    backdrop-filter: blur(10px);
  }

  .docs-progress-bar {
    width: 100%;
    height: 100%;
    transform-origin: left center;
    transform: scaleX(0);
    background: linear-gradient(90deg, var(--sky), var(--indigo));
    box-shadow: 0 0 24px color-mix(in srgb, var(--sky) 30%, transparent);
  }

  .docs-layout {
    display: grid;
    grid-template-columns: 1fr;
    min-height: calc(100vh - 64px);
    margin-top: 68px;
  }

  .docs-sidebar {
    display: none;
  }

  .docs-toc {
    display: none;
  }

  .docs-content {
    max-width: 100%;
    padding: 32px 20px;
    overflow-x: hidden;
    background: var(--surface-base);
  }

  .sidebar-dialog-close {
    float: right;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    border: 1px solid var(--line-soft);
    background: var(--surface-soft);
    color: var(--text-strong);
    cursor: pointer;
    transition: background 0.2s var(--ease-out-expo), border-color 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo);
  }

  .sidebar-dialog-close-icon {
    width: 20px;
    height: 20px;
  }

  .sidebar-dialog-close:hover {
    background: var(--interactive-bg);
    border-color: var(--interactive-border-strong);
    color: var(--sky);
  }

  @media (min-width: 1024px) {
    .docs-layout {
      grid-template-columns: 260px 1fr;
    }

    .docs-sidebar {
      display: block;
      position: sticky;
      top: 64px;
      height: calc(100vh - 64px);
      overflow-y: auto;
      padding: 24px 16px;
      border-right: 1px solid var(--border);
      background: var(--surface-soft);
    }

    .docs-content {
      padding: 40px 48px;
    }
  }

  @media (min-width: 1280px) {
    .docs-layout {
      grid-template-columns: 260px 1fr 220px;
    }

    .docs-toc {
      display: block;
      position: sticky;
      top: 64px;
      height: calc(100vh - 64px);
      overflow-y: auto;
      padding: 24px 16px;
      border-left: 1px solid var(--border);
      background: var(--surface-soft);
    }
  }
</style>
