---
// ThemeToggle.astro
import { Icon } from 'astro-icon/components';
---

<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle theme" aria-pressed="false" type="button">
  <Icon name="lucide:sun" class="sun theme-toggle-icon" aria-hidden="true" />
  <Icon name="lucide:moon" class="moon theme-toggle-icon" aria-hidden="true" />
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--header-control-bg, var(--surface-raised));
    border: 1px solid var(--header-control-border, var(--line-soft));
    color: var(--header-muted, var(--text-muted));
    padding: 0;
    border-radius: 10px;
    cursor: pointer;
    transition: background-color 0.2s var(--ease-out-expo), border-color 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo);
    position: relative;
    width: 44px;
    height: 44px;
  }

  .theme-toggle:hover {
    background: var(--header-control-hover-bg, var(--surface-soft));
    border-color: var(--header-control-hover-border, var(--interactive-border-strong));
    color: var(--header-control-hover-fg, var(--text-strong));
  }

  .theme-toggle-icon {
    width: 20px;
    height: 20px;
  }

  .sun { display: none; }
  .moon { display: block; }

  :global(.dark) .sun { display: block; }
  :global(.dark) .moon { display: none; }
</style>

<script>
  const syncToggleState = () => {
    const button = document.getElementById("theme-toggle");
    if (!button) return;

    const isDark = document.documentElement.classList.contains("dark");
    const label = isDark ? "Switch to light mode" : "Switch to dark mode";

    button.setAttribute("aria-pressed", String(isDark));
    button.setAttribute("aria-label", label);
    button.setAttribute("title", label);
  };

  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    syncToggleState();
  };

  syncToggleState();
  document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);
</script>
