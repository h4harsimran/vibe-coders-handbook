---
import { Icon } from 'astro-icon/components';

const audiences = [
  {
    icon: 'lucide:bot',
    title: 'AI-Assisted Builders',
    desc: "You ship apps using Cursor, v0, Bolt, or Claude. The code works — but you're not sure why. This book fills that gap.",
    example: '"What even is a Server Component?"',
    accent: 'var(--indigo)',
  },
  {
    icon: 'lucide:undo-2',
    title: 'Returning Developers',
    desc: "You coded back in the day and found the ecosystem totally unrecognizable. It's not you — everything genuinely changed.",
    example: '"I remember jQuery. What happened?"',
    accent: 'var(--violet)',
  },
  {
    icon: 'lucide:blocks',
    title: 'Founders & PMs',
    desc: 'You work alongside engineers and want to make better decisions without needing a computer science degree.',
    example: '"Should we use Prisma or Drizzle?"',
    accent: 'var(--green)',
  },
  {
    icon: 'lucide:library-big',
    title: 'Self-Taught Beginners',
    desc: "Every tutorial assumes you already know things. This book doesn't. It starts from what each tool actually is.",
    example: '"Why do I even need TypeScript?"',
    accent: 'var(--sky)',
  },
];
---

<section class="audience-section" id="audience">
  <div class="audience-inner">
    <div class="aud-header">
      <span class="section-tag">Who it's for</span>
      <h2 class="aud-heading">You don't need to be a "real" developer</h2>
      <p class="aud-subhead">If you've ever asked one of these questions, this handbook is written for you.</p>
    </div>

    <div class="aud-grid">
      {audiences.map(a => (
        <div class="aud-card">
          <div class="aud-head">
            <div class="aud-icon-wrap" style={`--aud-accent: ${a.accent};`}>
              <Icon name={a.icon} class="aud-icon" aria-hidden="true" />
            </div>
            <h3 class="aud-title">{a.title}</h3>
          </div>
          <blockquote class="aud-example">{a.example}</blockquote>
          <p class="aud-desc">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .audience-section {
    padding: 72px var(--space-md);
    background:
      linear-gradient(180deg, var(--surface-base), color-mix(in srgb, var(--surface-soft) 58%, var(--surface-raised)));
  }

  .audience-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 44px);
    border-radius: 32px;
    border: 1px solid var(--line-soft);
    background:
      radial-gradient(circle at bottom left, color-mix(in srgb, var(--indigo) 8%, transparent), transparent 36%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-raised) 96%, var(--surface-soft)), var(--surface-raised));
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.07);
  }

  .aud-header {
    max-width: 520px;
    margin-bottom: 56px;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sky);
    padding: 8px 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--interactive-bg) 80%, var(--surface-raised));
    border: 1px solid var(--interactive-border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
    margin-bottom: 12px;
  }

  .aud-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-strong);
    margin: 0 0 12px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 13ch;
    text-wrap: balance;
  }

  .aud-subhead {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .aud-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .aud-card {
    background: var(--surface-raised);
    border: 1px solid var(--line-soft);
    @apply rounded-xl p-8;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s var(--ease-out-quart), box-shadow 0.2s var(--ease-out-quart), transform 0.2s var(--ease-out-quart);
  }

  .aud-card:hover {
    background: var(--surface-soft);
    border-color: var(--interactive-border-strong);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .aud-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .aud-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    color: var(--aud-accent);
    background: color-mix(in srgb, var(--aud-accent) 10%, var(--surface-raised));
    border: 1px solid color-mix(in srgb, var(--aud-accent) 22%, var(--line-soft));
  }

  .aud-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .aud-example {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--sky);
    background: var(--interactive-bg);
    border: 1px solid var(--interactive-border);
    border-radius: 6px;
    padding: 8px 12px;
    margin: 0;
    font-style: italic;
    line-height: 1.5;
  }

  .aud-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    text-wrap: balance;
  }

  .aud-desc {
    font-size: 13.5px;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 900px) {
    .audience-section { padding: 56px 24px; }
    .audience-inner { padding: 24px; border-radius: 24px; }
    .aud-grid { grid-template-columns: repeat(2, 1fr); }
    .aud-header { max-width: 100%; }
  }

  @media (max-width: 500px) {
    .aud-grid { grid-template-columns: 1fr; }
    .aud-head { align-items: flex-start; }
  }
</style>
