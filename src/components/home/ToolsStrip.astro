---
import { Icon } from 'astro-icon/components';

const tools = [
  { label: 'React', icon: 'simple-icons:react', color: '#61DAFB' },
  { label: 'Next.js', icon: 'simple-icons:nextdotjs', color: 'currentColor' },
  { label: 'TypeScript', icon: 'simple-icons:typescript', color: '#3178C6' },
  { label: 'Node.js', icon: 'simple-icons:nodedotjs', color: '#5FA04E' },
  { label: 'Tailwind', icon: 'simple-icons:tailwindcss', color: '#06B6D4' },
  { label: 'Express', icon: 'simple-icons:express', color: 'currentColor' },
  { label: 'Drizzle', icon: 'simple-icons:drizzle', color: '#C5F74F' },
  { label: 'Prisma', icon: 'simple-icons:prisma', color: '#2D3748' },
  { label: 'Zustand', icon: 'lucide:layers-3', color: 'var(--indigo)' },
  { label: 'Zod', icon: 'simple-icons:zod', color: '#3E67B1' },
  { label: 'Vue', icon: 'simple-icons:vuedotjs', color: '#42B883' },
  { label: 'Svelte', icon: 'simple-icons:svelte', color: '#FF3E00' },
  { label: 'Vite', icon: 'simple-icons:vite', color: '#646CFF' },
  { label: 'TanStack Query', icon: 'simple-icons:tanstack', color: '#FF4154' },
  { label: 'Supabase', icon: 'simple-icons:supabase', color: '#3ECF8E' },
  { label: 'Vercel', icon: 'simple-icons:vercel', color: 'currentColor' },
  { label: 'Angular', icon: 'simple-icons:angular', color: '#DD0031' },
  { label: 'Fastify', icon: 'simple-icons:fastify', color: 'currentColor' },
  { label: 'NestJS', icon: 'simple-icons:nestjs', color: '#E0234E' },
  { label: 'SWR', icon: 'simple-icons:swr', color: '#000000' },
  { label: 'Hono', icon: 'simple-icons:hono', color: '#E36002' },
  { label: 'Bun', icon: 'simple-icons:bun', color: '#FBF0DF' },
  { label: 'Deno', icon: 'simple-icons:deno', color: 'currentColor' },
  { label: 'Remix', icon: 'simple-icons:remix', color: 'currentColor' },
  { label: 'Astro', icon: 'simple-icons:astro', color: '#FF5D01' },
  { label: 'Nuxt', icon: 'simple-icons:nuxt', color: '#00DC82' },
];
---

<div class="ecosystem-strip">
  <div class="strip-track">
    <div class="strip-items">
      {[...tools, ...tools, ...tools].map((tool, i) => (
        <span class="strip-chip" data-idx={i % tools.length}>
          <Icon
            name={tool.icon}
            class="strip-chip-icon"
            style={`color: ${tool.color};`}
            aria-hidden="true"
          />
          <span>{tool.label}</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .ecosystem-strip {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 50%, var(--bg)), color-mix(in srgb, var(--surface-raised) 70%, var(--bg)));
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    contain: layout style;
  }

  .strip-track {
    overflow: hidden;
  }

  .strip-items {
    display: flex;
    gap: 0;
    animation: slide 40s linear infinite;
    width: max-content;
    will-change: transform;
    transform: translateZ(0);
  }

  /* Pause on hover and focus-within for accessibility */
  .strip-track:hover .strip-items,
  .strip-track:focus-within .strip-items {
    animation-play-state: paused;
  }

  .strip-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-strong);
    padding: 14px 18px;
    border-right: 1px solid var(--line-soft);
    white-space: nowrap;
    transition: background-color 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo);
  }

  .strip-chip-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.92;
  }

  .strip-chip:hover {
    background: color-mix(in srgb, var(--surface-soft) 72%, transparent);
    color: var(--sky);
    cursor: default;
  }

  @keyframes slide {
    from { transform: translateX(0) translateZ(0); }
    to { transform: translateX(calc(-100% / 3)) translateZ(0); }
  }
  @media (max-width: 640px) {
    .strip-chip {
      gap: 8px;
      padding: 12px 14px;
      font-size: 12px;
    }

    .strip-chip-icon {
      width: 14px;
      height: 14px;
    }
  }
</style>
