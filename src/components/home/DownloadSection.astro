---
import { Icon } from 'astro-icon/components';
---

<section class="download-section" id="download">
  <div class="download-inner">
    <div class="download-main">
      <div class="section-header">
        <span class="section-tag">Get the Handbook</span>
        <h2 class="section-heading">Take it with you</h2>
        <p class="section-desc">Read online, download the PDF, or explore the source on GitHub. Everything stays free and community-maintained.</p>
      </div>

      <div class="download-grid">
        <div class="download-card">
          <div class="card-icon">
            <Icon name="lucide:book-open-text" class="download-card-icon" aria-hidden="true" />
          </div>
          <div class="card-content">
            <h3 class="card-title">Read Online</h3>
            <p class="card-text">Best if you want the full handbook experience with navigation, search, and chapter-by-chapter reading.</p>
          </div>
          <a href="/chapters/introduction" class="card-action">Start Reading</a>
        </div>

        <div class="download-card">
          <div class="card-icon">
            <Icon name="lucide:file-text" class="download-card-icon" aria-hidden="true" />
          </div>
          <div class="card-content">
            <h3 class="card-title">PDF Document</h3>
            <p class="card-text">Best for reading on tablets, Kindles, or printing for offline use.</p>
          </div>
          <a href="/TheVibeCodersHandbook.pdf" class="card-action" download>Download PDF</a>
        </div>

        <div class="download-card">
          <div class="card-icon">
            <Icon name="simple-icons:github" class="download-card-icon" aria-hidden="true" />
          </div>
          <div class="card-content">
            <h3 class="card-title">Markdown / GitHub</h3>
            <p class="card-text">The raw source. Best for contributing or hosting your own version.</p>
          </div>
          <a href="https://github.com/h4harsimran/vibe-coders-handbook" class="card-action" target="_blank" rel="noopener">GitHub Repo</a>
        </div>
      </div>
    </div>

    <div class="download-footer">
      <div class="footer-msg">
        <Icon name="lucide:shield-check" class="footer-msg-icon" aria-hidden="true" />
        <span>No signup. No email. No tracking. Just the book.</span>
      </div>
    </div>
  </div>
</section>

<style>
  .download-section {
    padding: 72px 80px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-raised) 55%, var(--surface-soft)), var(--surface-base));
  }

  .download-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 44px);
    border-radius: 32px;
    border: 1px solid var(--line-soft);
    background:
      radial-gradient(circle at bottom right, color-mix(in srgb, var(--indigo) 8%, transparent), transparent 34%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-raised) 96%, var(--surface-soft)), var(--surface-raised));
    box-shadow: 0 24px 72px rgba(15, 23, 42, 0.07);
  }

  .section-header {
    max-width: 500px;
    margin-bottom: 56px;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sky);
    padding: 8px 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--interactive-bg) 80%, var(--surface-raised));
    border: 1px solid var(--interactive-border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    color: var(--text-strong);
    margin: 0 0 16px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 12ch;
    text-wrap: balance;
  }

  .section-desc {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .download-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }

  .download-card {
    background: var(--surface-raised);
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: border-color 0.2s var(--ease-out-quart), box-shadow 0.2s var(--ease-out-quart), transform 0.2s var(--ease-out-quart);
  }

  .download-card:hover {
    background: var(--surface-soft);
    border-color: var(--interactive-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--indigo);
  }

  .download-card-icon {
    width: 28px;
    height: 28px;
  }

  .card-content {
    flex: 1;
  }

  .card-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    font-weight: 650;
    color: var(--text-strong);
    margin: 0 0 8px;
    text-wrap: balance;
  }

  .card-text {
    font-size: 13.5px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .card-action {
    display: flex;
    justify-content: center;
    background: var(--surface-soft);
    color: var(--text-strong);
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 12px;
    border-radius: 8px;
    border: 1px solid var(--line-soft);
    transition: background 0.2s var(--ease-out-expo), border-color 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo);
  }

  .download-card:hover .card-action {
    background: linear-gradient(135deg, var(--blue), var(--indigo));
    color: var(--text-on-dark);
    border-color: transparent;
  }

  .download-footer {
    display: flex;
    justify-content: flex-start;
  }

  .footer-msg {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--surface-raised);
    padding: 12px 20px;
    border-radius: 100px;
    border: 1px solid var(--line-soft);
  }

  .footer-msg-icon {
    width: 20px;
    height: 20px;
    color: var(--green);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .download-section { padding: 56px 24px; }
    .download-inner { padding: 24px; border-radius: 24px; }
    .download-grid { grid-template-columns: 1fr; }
  }
</style>
