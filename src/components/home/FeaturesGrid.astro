---
import { Icon } from 'astro-icon/components';

const features = [
  {
    tag: 'Navigation',
    title: 'The Complete Ecosystem Map',
    desc: 'Every tool, framework, and library covering what they do, why they exist, and which ones you actually need.',
    accent: 'var(--indigo)',
    icon: 'lucide:route',
  },
  {
    tag: 'Clarity',
    title: 'Real-World Analogies',
    desc: 'Concepts explained through restaurants, LEGO bricks, and everyday life — no jargon required.',
    accent: 'var(--sky)',
    icon: 'lucide:sparkles',
  },
  {
    tag: 'Decisions',
    title: 'Head-to-Head Comparisons',
    desc: 'React vs Vue, Prisma vs Drizzle — side-by-side so you know which to pick.',
    accent: 'var(--amber)',
    icon: 'lucide:scale',
  },
  {
    tag: 'Errors',
    title: 'Error Message Decoder',
    desc: 'The most common JS/TS error messages explained in one sentence each.',
    accent: 'var(--red)',
    icon: 'lucide:triangle-alert',
  },
  {
    tag: 'Security',
    title: 'Auth & Security Basics',
    desc: 'OAuth, JWTs, sessions, and the security concepts every builder must understand.',
    accent: 'var(--green)',
    icon: 'lucide:shield-check',
  },
  {
    tag: 'Resources',
    title: 'Curated Learning Paths',
    desc: 'The best free tutorials, docs, and courses for each topic — linked at the end of every chapter.',
    accent: 'var(--violet)',
    icon: 'lucide:library-big',
  },
];
---

<section class="features-section" id="features">
  <div class="features-inner">
    <div class="section-header">
      <span class="section-tag">What's Inside</span>
      <h2 class="section-heading">Six reasons this handbook is different</h2>
    </div>

    <div class="bento-grid">
      {features.map(f => (
        <div class="bento-card" style={`--accent: ${f.accent}`}>
          <div class="bento-tag">
            <span class="bento-tag-icon-wrap">
              <Icon name={f.icon} class="bento-tag-icon" aria-hidden="true" />
            </span>
            <span>{f.tag}</span>
          </div>
          <h3 class="bento-title">{f.title}</h3>
          <p class="bento-desc">{f.desc}</p>
          <div class="bento-bar" style={`background: ${f.accent}`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 72px var(--space-md);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 72%, var(--bg)), var(--surface-base));
  }

  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 44px);
    border-radius: 32px;
    border: 1px solid var(--line-soft);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--sky) 10%, transparent), transparent 34%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-raised) 92%, var(--surface-soft)), var(--surface-raised));
    box-shadow: 0 28px 80px rgba(15, 23, 42, 0.08);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 48px;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sky);
    padding: 8px 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--interactive-bg) 80%, var(--surface-raised));
    border: 1px solid var(--interactive-border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  .section-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 12ch;
    text-wrap: balance;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: auto;
    gap: 18px;
  }

  .bento-card {
    background: var(--surface-raised);
    border: 1px solid var(--line-soft);
    @apply rounded-xl p-8;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s var(--ease-out-quart), box-shadow 0.25s var(--ease-out-quart), transform 0.25s var(--ease-out-quart);
    display: flex;
    flex-direction: column;
    min-height: 260px;
    contain: content;
  }

  .bento-card:hover {
    border-color: var(--interactive-border-strong);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .bento-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 78%, var(--text-strong));
    margin-bottom: 16px;
    align-self: flex-start;
  }

  .bento-tag-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-soft));
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line-soft));
    color: var(--accent);
    flex-shrink: 0;
  }

  .bento-tag-icon {
    width: 12px;
    height: 12px;
  }

  .bento-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0 0 12px;
    line-height: 1.2;
    text-wrap: balance;
  }

  .bento-desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .bento-bar {
    height: 2px;
    width: 70px;
    border-radius: 2px;
    margin-top: 20px;
    opacity: 0.6;
    transform: scaleX(0.57) translateZ(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out-quart), opacity 0.3s var(--ease-out-quart);
  }

  .bento-card:hover .bento-bar {
    transform: scaleX(1) translateZ(0);
    opacity: 1;
  }

  @media (max-width: 900px) {
    .features-section { padding: 56px 20px; }
    .bento-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .features-inner { padding: 24px; border-radius: 24px; }
    .bento-card { padding: 24px; }
    .section-heading {
      font-size: var(--text-2xl);
      max-width: 14ch;
    }
  }

  @media (max-width: 600px) {
    .bento-grid { grid-template-columns: 1fr; }
    .bento-wide { grid-column: span 1; }
  }
</style>
